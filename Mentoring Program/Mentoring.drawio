        <mxCell id="PRU6ocnhfSUfhAS2T8r2-34" value="&lt;font style=&quot;&quot;&gt;&lt;font color=&quot;#10739e&quot;&gt;&lt;b&gt;Session Preparation&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;div style=&quot;line-height: 90%;&quot;&gt;&lt;font style=&quot;font-size: 7px;&quot;&gt;Mentor-mentee pairs are identified, matched, and announced, setting a clear foundation for the mentoring program and ensuring both participants and managers are aligned on expectations and goals.&lt;/font&gt;&lt;/div&gt;&lt;/font&gt;" style="rounded=1;strokeColor=none;fillColor=#EEEEEE;align=center;arcSize=12;verticalAlign=middle;whiteSpace=wrap;html=1;fontSize=12;spacing=3;shadow=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" vertex="1" parent="1">
